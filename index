        <span class="legend-item"><span class="legend-dot" style="background:#D4537E"></span>經濟案件</span>
      </div>
      <div style="position:relative;width:100%;height:220px;"><canvas id="otherChart"></canvas></div>
    </div>

    <div class="chart-card full">
      <div class="chart-header">
        <div class="chart-title" id="yearlyTitle">竊盜年度總計比較</div>
        <div class="btn-group">
