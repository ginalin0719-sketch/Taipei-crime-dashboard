function parseYear(label) { const m = label.match(/^(\d+)年/); return m ? parseInt(m[1]) : 0; }
function getYearRange() {
  const v = document.getElementById('yearFilter').value;
  if (v==='all') return [87,115];
  if (v==='recent10') return [105,115];
  if (v==='recent5') return [110,115];
  if (v==='recent3') return [112,115];
  return [87,115];
}
function filterByYear(data, minY, maxY) {
  return data.filter(d => { const y=parseYear(d[0]); return y>=minY && y<=maxY; });
}
function movingAvg(data, w) {
  return data.map((_,i) => {
    if (i<w-1) return null;
    return Math.round(data.slice(i-w+1,i+1).reduce((s,v)=>s+v,0)/w);
  });
}
function buildYearlyMap(data, extractor) {
  const map={};
  data.forEach(d=>{ const y=d[0].match(/^(\d+)年/)[1]; map[y]=(map[y]||0)+extractor(d); });
  return map;
}

let charts={};
let currentMode='theft';
const yearlyConfig={
  theft:    {label:'竊盜年度總計比較',    color:'#378ADD', extractor:d=>d[1], src:()=>theftRaw},
  violence: {label:'暴力犯罪年度總計比較', color:'#D85A30', extractor:d=>d[1], src:()=>violenceRaw},
  disorder: {label:'違序案件年度總計比較', color:'#7F77DD', extractor:d=>d[1], src:()=>otherRaw},
  economic: {label:'經濟案件年度總計比較', color:'#D4537E', extractor:d=>d[2], src:()=>otherRaw},
};

function switchYearly(mode, btn) {
  currentMode=mode;
  document.querySelectorAll('.btn-switch').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  updateYearlyChart();
}

function updateYearlyChart() {
  const [minY,maxY]=getYearRange();
  const cfg=yearlyConfig[currentMode];
  const filtered=filterByYear(cfg.src(),minY,maxY);
  const map=buildYearlyMap(filtered,cfg.extractor);
  const keys=Object.keys(map).sort((a,b)=>+a-+b);
  const vals=keys.map(k=>map[k]);
  const maxVal=Math.max(...vals);
  document.getElementById('yearlyTitle').textContent=cfg.label;
  if(charts.yearly) charts.yearly.destroy();
  charts.yearly=new Chart(document.getElementById('yearlyBar'),{
    type:'bar',
    data:{
      labels:keys.map(k=>k+'年'),
      datasets:[{label:cfg.label,data:vals,backgroundColor:vals.map(v=>v===maxVal?'#D85A30':cfg.color)}]
    },
    options:{
      responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>' '+ctx.parsed.y.toLocaleString()+' 件'}}},
      scales:{x:{ticks:{autoSkip:false,maxRotation:45,font:{size:10}},grid:{display:false}},y:{ticks:{font:{size:10}}}}
    }
  });
}

function updateAll() {
  const [minY,maxY]=getYearRange();
  const theftF=filterByYear(theftRaw,minY,maxY);
  const violenceF=filterByYear(violenceRaw,minY,maxY);
  const otherF=filterByYear(otherRaw,minY,maxY);
  const theftVals=theftF.map(d=>d[1]);
  const theftMA=movingAvg(theftVals,12);
  const latestTheft=theftVals[theftVals.length-1];
  const prevTheft=theftVals[theftVals.length-13]||theftVals[0];
  const avgTheft=Math.round(theftVals.reduce((s,v)=>s+v,0)/theftVals.length);
  const latestViolence=violenceF.length?violenceF[violenceF.length-1][1]:0;
  const violenceTot=violenceF.reduce((s,d)=>s+d[1],0);
  const latestOtherVio=otherF.length?otherF[otherF.length-1][1]:0;
  const latestEcon=otherF.length?otherF[otherF.length-1][2]:0;

  document.getElementById('metrics').innerHTML=`
    <div class="metric"><div class="label">最新月竊盜件數</div><div class="value">${latestTheft.toLocaleString()}</div><div class="sub">月平均 ${avgTheft.toLocaleString()} 件</div><div class="delta ${latestTheft<prevTheft?'down':'up'}">${latestTheft<prevTheft?'▼':'▲'} 去年同期 ${Math.abs(latestTheft-prevTheft)} 件</div></div>
    <div class="metric"><div class="label">最新月暴力犯罪</div><div class="value">${latestViolence}</div><div class="sub">區間合計 ${violenceTot.toLocaleString()} 件</div></div>
    <div class="metric"><div class="label">最新月違序 / 經濟</div><div class="value">${latestOtherVio} / ${latestEcon}</div><div class="sub">違序件數 / 經濟案件</div></div>
  `;

  ['theft','violence','other'].forEach(k=>{ if(charts[k]) charts[k].destroy(); });

  charts.theft=new Chart(document.getElementById('theftChart'),{
    type:'line',
    data:{labels:theftF.map(d=>d[0].replace('年 ','/')),datasets:[
      {label:'竊盜總計',data:theftVals,borderColor:'#378ADD',backgroundColor:'rgba(55,138,221,0.08)',borderWidth:1.5,pointRadius:0,tension:0.3,fill:true},
      {label:'12月移動平均',data:theftMA,borderColor:'#1D9E75',borderWidth:2,pointRadius:0,tension:0.3,borderDash:[4,3]}
    ]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{mode:'index',intersect:false}},scales:{x:{ticks:{maxTicksLimit:12,maxRotation:45,font:{size:10}},grid:{display:false}},y:{ticks:{font:{size:10}},beginAtZero:false}}}
  });

  charts.violence=new Chart(document.getElementById('violenceChart'),{
    type:'bar',
    data:{labels:violenceF.map(d=>d[0].replace('年 ','/')),datasets:[
      {label:'強制性交',data:violenceF.map(d=>d[2]),backgroundColor:'#D85A30',stack:'v'},
      {label:'強盜搶奪',data:violenceF.map(d=>d[3]),backgroundColor:'#BA7517',stack:'v'},
      {label:'其他',data:violenceF.map(d=>d[4]),backgroundColor:'#A32D2D',stack:'v'}
    ]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{mode:'index',intersect:false}},scales:{x:{stacked:true,ticks:{maxTicksLimit:10,maxRotation:45,font:{size:10}},grid:{display:false}},y:{stacked:true,ticks:{font:{size:10}},beginAtZero:true}}}
  });

  charts.other=new Chart(document.getElementById('otherChart'),{
    type:'line',
    data:{labels:otherF.map(d=>d[0].replace('年 ','/')),datasets:[
      {label:'違序件數',data:otherF.map(d=>d[1]),borderColor:'#7F77DD',backgroundColor:'rgba(127,119,221,0.07)',borderWidth:1.5,pointRadius:0,tension:0.3,fill:true},
      {label:'經濟案件',data:otherF.map(d=>d[2]),borderColor:'#D4537E',borderWidth:1.5,pointRadius:0,tension:0.3}
    ]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{mode:'index',intersect:false}},scales:{x:{ticks:{maxTicksLimit:10,maxRotation:45,font:{size:10}},grid:{display:false}},y:{ticks:{font:{size:10}},beginAtZero:true}}}
  });

  updateYearlyChart();
}

updateAll();
