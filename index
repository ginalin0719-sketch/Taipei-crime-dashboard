<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #f5f5f7; color: #1d1d1f; min-height: 100vh; }
  .page { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; }
  h1 { font-size: 22px; font-weight: 600; color: #1d1d1f; }
  .subtitle { font-size: 13px; color: #6e6e73; margin-top: 4px; margin-bottom: 1.5rem; }
  .controls { display: flex; gap: 8px; margin-bottom: 1.5rem; align-items: center; }
  .controls label { font-size: 13px; color: #6e6e73; }
  select { font-size: 13px; padding: 5px 10px; border-radius: 8px; border: 1px solid #d2d2d7; background: #fff; color: #1d1d1f; cursor: pointer; outline: none; }
  select:focus { border-color: #0071e3; }
  .metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 1.5rem; }
  .metric { background: #fff; border-radius: 12px; padding: 1.1rem 1.2rem; box-shadow: 0 1px 4px rgba(0,0,0,0.07); }
  .metric .label { font-size: 12px; color: #6e6e73; margin-bottom: 6px; }
  .metric .value { font-size: 24px; font-weight: 600; color: #1d1d1f; }
  .metric .sub { font-size: 11px; color: #aeaeb2; margin-top: 4px; }
  .metric .delta { font-size: 12px; margin-top: 4px; font-weight: 500; }
  .delta.down { color: #28cd41; }
  .delta.up { color: #ff3b30; }
  .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .chart-card { background: #fff; border-radius: 14px; padding: 1.1rem 1.3rem; box-shadow: 0 1px 4px rgba(0,0,0,0.07); }
  .chart-card.full { grid-column: 1 / -1; }
  .chart-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.9rem; }
  .chart-title { font-size: 13px; font-weight: 600; color: #6e6e73; }
  .legend { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 10px; font-size: 11px; color: #6e6e73; }
  .legend-item { display: flex; align-items: center; gap: 4px; }
  .legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }
  .btn-group { display: flex; gap: 4px; flex-wrap: wrap; }
  .btn-switch { font-size: 11px; padding: 4px 11px; border-radius: 20px; border: 1px solid #d2d2d7; background: #f5f5f7; color: #6e6e73; cursor: pointer; transition: all 0.15s; font-weight: 500; }
  .btn-switch:hover { background: #e8e8ed; }
  .btn-switch.active { background: #0071e3; color: #fff; border-color: #0071e3; }
  footer { text-align: center; font-size: 12px; color: #aeaeb2; margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #e5e5ea; }
  @media (max-width: 640px) {
    .charts-grid { grid-template-columns: 1fr; }
    .chart-card.full { grid-column: 1; }
    .metrics { grid-template-columns: 1fr; }
    .chart-header { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>
</head>
